# Copy to .env and fill in. .env is gitignored — never commits.

# === Active (free) stack ===

# Google Gemini — LLM + embeddings. Free, no card: aistudio.google.com
GEMINI_API_KEY=

# LLM fallback chain (order via LLM_CHAIN, default "qwen,groq,gemini").
# Providers without a key are skipped. Qwen via OpenRouter, Groq via Groq Cloud.
QWEN_API_KEY=
GROQ_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# Access control. Only these email(s) become admin automatically; all other
# accounts start as user until an admin changes their role.
APP_ADMIN_EMAILS=rk26.ftw@gmail.com
DEFAULT_ORGANIZATION_NAME=iORA Workspace

# === Provider switches (defaults are free Gemini) ===
# LLM_PROVIDER=gemini      # gemini | claude
# EMBED_PROVIDER=gemini    # gemini | voyage

# === Optional: only if you switch providers later ===
# ANTHROPIC_API_KEY=       # for LLM_PROVIDER=claude (paid)
# VOYAGE_API_KEY=          # for EMBED_PROVIDER=voyage
