{
  "buildCommand": "bash scripts/vercel-build.sh",
  "outputDirectory": "public",
  "installCommand": "python3 -m pip install -r requirements.txt",
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/((?!_next/.*|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
