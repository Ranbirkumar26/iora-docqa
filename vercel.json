{
  "services": {
    "docqa": {
      "root": ".",
      "entrypoint": "api.index:app",
      "buildCommand": "bash scripts/vercel-build.sh",
      "installCommand": "python3 -m pip install -r requirements-vercel.txt",
      "functions": {
        "api/index.py": {
          "maxDuration": 60
        }
      }
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": {
        "service": "docqa"
      }
    }
  ]
}
